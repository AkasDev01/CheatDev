-- Spoofer Module
local Spoofer = {}

Spoofer.State = {
    Enabled = false,
    Clone = nil,
    JointMap = {},
    UpdateCount = 0
}

function Spoofer.createClone()
    if Spoofer.State.Clone then
        pcall(function() Spoofer.State.Clone:Destroy() end)
        Spoofer.State.Clone = nil
    end
    
    local currentChar = game.Players.LocalPlayer.Character
    if not currentChar then return false
    
    currentChar.Archivable = true
    local clone = currentChar:Clone()
    currentChar.Archivable = false
    clone.Name = "SpooferClone"
    
    for _, obj in pairs(clone:GetDescendants()) do
        if obj:IsA("LuaSourceContainer") or obj:IsA("Sound") or obj:IsA("TouchTransmitter") then
            obj:Destroy()
        elseif obj:IsA("BasePart") then
            obj.Anchored = true
            obj.CanCollide = false
            obj.Massless = true
            obj.CanTouch = false
            obj.CanQuery = false
            obj.Color = Color3.fromRGB(100, 150, 255)
            obj.Material = Enum.Material.Neon
            obj.Transparency = 0.5
            if obj:IsA("MeshPart") then
                obj.TextureID = ""
            end
            local mesh = obj:FindFirstChildOfClass("SpecialMesh")
            if mesh then
                mesh.TextureId = ""
            end
        end
        if obj:IsA("Accessory") or obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("BodyColors") or obj:IsA("ShirtGraphic") then
            obj:Destroy()
        end
    end
    
    local hum = clone:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
        hum.HealthDisplayType = Enum.HumanoidHealthDisplayType.AlwaysOff
        hum.PlatformStand = true
        hum:ChangeState(Enum.HumanoidStateType.Physics)
    end
    
    local highlight = Instance.new("Highlight")
    highlight.Parent = clone
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Enabled = true
    highlight.FillColor = Color3.fromRGB(100, 150, 255)
    highlight.OutlineColor = Color3.fromRGB(150, 180, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    
    clone.Parent = workspace
    Spoofer.State.Clone = clone
    
    Spoofer.State.JointMap = {}
    for _, cloneJoint in pairs(clone:GetDescendants()) do
        if cloneJoint:IsA("Motor6D") then
            local realJoint = currentChar:FindFirstChild(cloneJoint.Name, true)
            if realJoint and realJoint:IsA("Motor6D") then
                Spoofer.State.JointMap[cloneJoint] = realJoint
            end
        end
    end
    
    return true
end

function Spoofer.update()
    if not getgenv().Settings.Spoofer then
        if Spoofer.State.Clone then
            pcall(function() Spoofer.State.Clone:Destroy() end)
            Spoofer.State.Clone = nil
        end
        return
    end
    
    local shouldWork = (getgenv().Settings.AutoKill and getgenv().lockedTarget) or getgenv().Settings.VoidWalk
    
    if not shouldWork then
        if Spoofer.State.Clone and Spoofer.State.Clone.Parent then
            Spoofer.State.Clone:Destroy()
            Spoofer.State.Clone = nil
        end
        return
    end
    
    if not Spoofer.State.Clone or not Spoofer.State.Clone.Parent then
        local success = Spoofer.createClone()
        if not success then return end
    end
    
    if not Spoofer.State.Clone then return end
    
    local cloneRoot = Spoofer.State.Clone:FindFirstChild("HumanoidRootPart")
    if not cloneRoot then return end
    
    if getgenv().Settings.AutoKill and getgenv().lockedTarget then
        local targetChar = nil
        if typeof(getgenv().lockedTarget) == "Instance" and getgenv().lockedTarget:IsA("Player") then
            targetChar = getgenv().lockedTarget.Character
        else
            if getgenv().Settings.TargetName then
                local recovered = game.Players:FindFirstChild(getgenv().Settings.TargetName)
                getgenv().lockedTarget = recovered
                if recovered then targetChar = recovered.Character end
            end
        end
        
        if targetChar then
            local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
            if targetHRP then
                cloneRoot.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 4)
            end
        end
    elseif getgenv().Settings.VoidWalk then
        cloneRoot.CFrame = CFrame.new(
            math.random(-999999, 999999),
            math.random(0, 999999),
            math.random(-999999, 999999)
        )
    end
    
    for cloneJoint, realJoint in pairs(Spoofer.State.JointMap) do
        if realJoint and realJoint.Parent and cloneJoint and cloneJoint.Parent then
            cloneJoint.Transform = realJoint.Transform
        end
    end
    
    local realChar = game.Players.LocalPlayer.Character
    local clone = Spoofer.State.Clone
    if realChar and clone then
        local realTool = realChar:FindFirstChildOfClass("Tool")
        local cloneTool = clone:FindFirstChildOfClass("Tool")
        
        if not realTool then
            if cloneTool then cloneTool:Destroy() end
        else
            if not cloneTool or cloneTool.Name ~= realTool.Name then
                if cloneTool then cloneTool:Destroy() end
                cloneTool = realTool:Clone()
                for _, v in pairs(cloneTool:GetDescendants()) do
                    if v:IsA("Script") or v:IsA("LocalScript") or v:IsA("Sound") then
                        v:Destroy()
                    elseif v:IsA("BasePart") then
                        v.CanCollide = false
                        v.Massless = true
                        v.CanTouch = false
                        v.CanQuery = false
                        v.Anchored = false
                        v.Color = Color3.fromRGB(100, 150, 255)
                        v.Material = Enum.Material.Neon
                        v.Transparency = 0.5
                    end
                end
                cloneTool.Parent = clone
            end
            
            local realHand = realChar:FindFirstChild("RightHand") or realChar:FindFirstChild("Right Arm")
            local cloneHand = clone:FindFirstChild("RightHand") or clone:FindFirstChild("Right Arm")
            local cloneHandle = cloneTool:FindFirstChild("Handle")
            
            if cloneHand and cloneHandle then
                local weld = cloneHandle:FindFirstChild("SpooferGripWeld")
                if not weld then
                    weld = Instance.new("Weld")
                    weld.Name = "SpooferGripWeld"
                    weld.Part0 = cloneHand
                    weld.Part1 = cloneHandle
                    weld.Parent = cloneHandle
                end
                if realHand then
                    local realGrip = realHand:FindFirstChild("RightGrip")
                    if realGrip then
                        weld.C0 = realGrip.C0
                        weld.C1 = realGrip.C1
                    else
                        weld.C0 = CFrame.new(0, -1, 0, 1, 0, 0, 0, 0, 1, 0, -1, 0)
                        weld.C1 = realTool.Grip
                    end
                end
            end
        end
    end
    
    local shouldShow = (getgenv().Settings.AutoKill and getgenv().lockedTarget) or getgenv().Settings.VoidWalk
    for _, part in pairs(Spoofer.State.Clone:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = shouldShow and 0.5 or 1
        end
    end
    
    local highlight = Spoofer.State.Clone:FindFirstChildOfClass("Highlight")
    if highlight then
        highlight.Enabled = shouldShow
    end
end

function Spoofer.startUpdate()
    if Spoofer.updateConnection then
        Spoofer.updateConnection:Disconnect()
    end
    Spoofer.updateConnection = game:GetService("RunService").Heartbeat:Connect(Spoofer.update)
end

function Spoofer.stopUpdate()
    if Spoofer.updateConnection then
        Spoofer.updateConnection:Disconnect()
        Spoofer.updateConnection = nil
    end
    if Spoofer.State.Clone then
        pcall(function() Spoofer.State.Clone:Destroy() end)
        Spoofer.State.Clone = nil
    end
end

function Spoofer.setupUI(PlayerGroup)
    local SpooferToggle = PlayerGroup:AddToggle('SpooferToggle', {
        Text = 'Spoofer', Default = false,
        Tooltip = 'Create a clone that attacks target while you stay hidden',
        Callback = function(Value)
            getgenv().Settings.Spoofer = Value
            if Value then
                task.spawn(function()
                    Spoofer.createClone()
                    Spoofer.startUpdate()
                end)
            else
                Spoofer.stopUpdate()
            end
        end
    })
    return SpooferToggle
end

return Spoofer
